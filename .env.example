PORT=3030
# Cloud persistent storage path. On Render this is /var/data.
DATA_DIR=data
APP_SECRET=change-this-login-secret
DATA_SECRET=change-this-data-secret

# Local fallback login. Google Sheet login is used when GOOGLE_SHEET_ID is set.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=12345
ADMIN_EXPIRES_AT=2099-12-31
ADMIN_NAME=Admin

# Forgot password WhatsApp contact.
FORGOT_WHATSAPP_NUMBER=+923357631909

# Google Sheet login columns: email, password, expires_at, status, name
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Users!A:E
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=

# OpenAI defaults used when a saved AI key does not override model.
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
DEFAULT_OPENAI_MODEL=gpt-5.5
OPENAI_TRANSCRIPTIONS_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Optional ISO language code. Leave blank for auto-detect. Urdu is ur, English is en.
OPENAI_TRANSCRIPTION_LANGUAGE=
# Optional words/context to improve voice note transcription.
OPENAI_TRANSCRIPTION_PROMPT=

# Optional when using whatsapp-web.js on Windows/VPS.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
